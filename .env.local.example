# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# React app variables (used in browser — password hashing only, no secrets)
REACT_APP_PASSWORD_HASH=your_hash_here
REACT_APP_SALT=coasting2026
REACT_APP_SESSION_SECRET=your_session_secret_here

# Server-side variables (never exposed to browser)
ANTHROPIC_API_KEY=sk-ant-your_key_here
SESSION_SECRET=your_session_secret_here
